@startuml
hide <<Path>> circle
hide <<Response>> circle
hide <<Parameter>> circle
hide empty methods
hide empty fields
skinparam class {
BackgroundColor<<Path>> Wheat
}
set namespaceSeparator none

class "employee" {
  {field} null : doctor {O}
  {field} null : nurse {O}
}

class "nurse" {
  {field} level : integer
}

class "doctor" {
  {field} income : decimal
}

"employee" --> "1" "doctor"

"employee" --> "1" "nurse"

@enduml